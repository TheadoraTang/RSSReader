{
  "name": "ripple",
  "version": "0.1.6",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev:desktop": "node scripts/dev-desktop.js",
    "dev:desktop:built": "npm run build:frontend && cross-env RSSREADER_USE_BUILT_FRONTEND=1 RSSREADER_OPEN_DEVTOOLS=1 electron .",
    "build:frontend": "npm run build --prefix frontend",
    "build:backend": "node scripts/build-backend.js",
    "dist:desktop": "npm run build:frontend && npm run build:backend && electron-builder"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "cross-env": "^7.0.3"
  },
  "build": {
    "appId": "io.github.ripple.desktop",
    "productName": "Ripple",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "build/icon.ico",
      "build/icon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend/dist/RSSReaderBackend/",
        "to": "backend/RSSReaderBackend"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.news"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network"
    }
  }
}
